<!DOCTYPE html>
<html>
<head>
  <title><%= product.name %></title>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet" href="/shop/style.css">
</head>

<body>

  <%- include('../partials/nav') %>

  <div class="product-page">

    <div class="product-layout">

      <!-- PRODUCT IMAGE -->

      <div class="product-image-card">

        <img
          src="/admin/products/<%= product.id %>/image"
          alt="<%= product.name %>"
          class="product-image"
        >

      </div>

      <!-- PRODUCT DETAILS -->

      <div class="product-details">

        <div class="product-category">
          <%= product.category %>
        </div>

        <h1 class="product-title">
          <%= product.name %>
        </h1>

        <div class="product-price">
          ₹<%= product.price %>
        </div>

        <!-- PRODUCT RATING -->

        <div class="product-rating">

          <% if (product.reviewCount > 0) { %>

            <span class="stars">
              <%= "⭐".repeat(Math.round(product.averageRating)) %>
            </span>

            <span class="rating-text">
              <%= product.averageRating %>
              (<%= product.reviewCount %> reviews)
            </span>

          <% } else { %>

            <span class="no-rating">
              No reviews yet
            </span>

          <% } %>

        </div>

        <div class="product-highlight">
          🚚 Fast Delivery • Premium Quality • Secure Shopping
        </div>

        <div class="product-meta-grid">

          <div class="meta-card">

            <div class="meta-label">
              Stock Status
            </div>

            <div class="meta-value
              <%= product.stock > 10
                ? 'stock-in'
                : product.stock > 0
                ? 'stock-low'
                : 'stock-out'
              %>
            ">
              <% if (product.stock > 10) { %>
                In Stock (<%= product.stock %>)
              <% } else if (product.stock > 0) { %>
                Low Stock (<%= product.stock %>)
              <% } else { %>
                Out of Stock
              <% } %>
            </div>

          </div>

          <div class="meta-card">

            <div class="meta-label">
              Category
            </div>

            <div class="meta-value">
              <%= product.category %>
            </div>

          </div>

        </div>

        <div class="description-card">

          <h3 class="description-title">
            Product Description
          </h3>

          <p>
            <%= product.description %>
          </p>

        </div>

        <div class="action-buttons">

          <a
            href="/shop"
            class="btn btn-secondary"
          >
            ← Back to Shop
          </a>

          <form action="/shop/cart" method="POST">

            <input
              type="hidden"
              name="_csrf"
              value="<%= csrfToken %>"
            >

            <input
              type="hidden"
              name="productId"
              value="<%= product.id %>"
            >

            <input
              type="hidden"
              name="quantity"
              value="1"
            >

            <button
              class="btn btn-primary"
              type="submit"
              <%= product.stock <= 0 ? 'disabled' : '' %>
            >
              🛒
              <%= product.stock > 0 ? 'Add to Cart' : 'Out of Stock' %>
            </button>

          </form>

        </div>

      </div>

    </div>

    <!-- REVIEWS SECTION -->

    <div class="reviews-section">

      <h2 class="reviews-heading">
        Customer Reviews
      </h2>

      <!-- REVIEW FORM -->

      <% if (currentUser) { %>

        <% const existingReview = product.Reviews?.find(
          review => review.userId === currentUser.id
        ); %>

        <% if (existingReview) { %>

          <div class="review-form-card">

            <h3>
              Edit Your Review
            </h3>

            <form
              action="/shop/reviews/update/<%= existingReview.id %>"
              method="POST"
            >

              <input
                type="hidden"
                name="_csrf"
                value="<%= csrfToken %>"
              >

              <div class="form-group">

                <label>
                  Rating
                </label>

                <select
                  name="rating"
                  required
                  class="review-input"
                >

                  <% for(let i = 5; i >= 1; i--) { %>

                    <option
                      value="<%= i %>"
                      <%= existingReview.rating === i ? 'selected' : '' %>
                    >
                      <%= "⭐".repeat(i) %> (<%= i %>)
                    </option>

                  <% } %>

                </select>

              </div>

              <div class="form-group">

                <label>
                  Your Review
                </label>

                <textarea
                  name="comment"
                  required
                  rows="4"
                  class="review-input"
                ><%= existingReview.comment %></textarea>

              </div>

              <button
                type="submit"
                class="btn btn-primary"
              >
                Update Review
              </button>

            </form>

            <form
              action="/shop/reviews/delete/<%= existingReview.id %>"
              method="POST"
              style="margin-top: 10px;"
            >

              <input
                type="hidden"
                name="_csrf"
                value="<%= csrfToken %>"
              >

              <button
                type="submit"
                class="btn btn-danger"
                onclick="return confirm('Delete your review?')"
              >
                Delete Review
              </button>

            </form>

          </div>

        <% } else { %>

          <div class="review-form-card">

            <form
              action="/shop/reviews/<%= product.id %>"
              method="POST"
            >

              <input
                type="hidden"
                name="_csrf"
                value="<%= csrfToken %>"
              >

              <div class="form-group">

                <label>
                  Rating
                </label>

                <select
                  name="rating"
                  required
                  class="review-input"
                >
                  <option value="5">
                    ⭐⭐⭐⭐⭐ (5)
                  </option>

                  <option value="4">
                    ⭐⭐⭐⭐ (4)
                  </option>

                  <option value="3">
                    ⭐⭐⭐ (3)
                  </option>

                  <option value="2">
                    ⭐⭐ (2)
                  </option>

                  <option value="1">
                    ⭐ (1)
                  </option>

                </select>

              </div>

              <div class="form-group">

                <label>
                  Your Review
                </label>

                <textarea
                  name="comment"
                  required
                  rows="4"
                  class="review-input"
                  placeholder="Write your review..."
                ></textarea>

              </div>

              <button
                type="submit"
                class="btn btn-primary"
              >
                Submit Review
              </button>

            </form>

          </div>

        <% } %>

      <% } else { %>

        <div class="login-review-msg">

          Please
          <a href="/auth/login">
            login
          </a>
          to write a review.

        </div>

      <% } %>

      <!-- REVIEW LIST -->

      <div class="reviews-list">

        <% if (product.Reviews && product.Reviews.length > 0) { %>

          <% product.Reviews.forEach(review => { %>

            <div class="review-card">

              <div class="review-header">

                <div class="review-user">
                  <%= review.User.name %>
                </div>

                <div class="review-stars">
                  <%= "⭐".repeat(review.rating) %>
                </div>

              </div>

              <div class="review-comment">
                <%= review.comment %>
              </div>

              <div class="review-date">

                <%= new Date(review.createdAt)
                  .toLocaleDateString()
                %>

              </div>

            </div>

          <% }) %>

        <% } else { %>

          <div class="no-reviews">
            No reviews yet.
          </div>

        <% } %>

      </div>

    </div>

  </div>

</body>
</html>