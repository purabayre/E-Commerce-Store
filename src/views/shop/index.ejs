<!DOCTYPE html>
<html>
<head>
  <title>Shop</title>

  <style>
    .product-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
    }

    .product-card {
      border: 1px solid #ccc;
      padding: 15px;
      width: 250px;
    }
  </style>
</head>
<body>

<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<h1>Shop</h1>

<!-- SEARCH -->

<form action="/shop" method="GET">

  <input
    type="text"
    name="search"
    placeholder="Search products..."
    value="<%= searchTerm %>"
  >

  <button type="submit">
    Search
  </button>

</form>

<br>

<!-- CATEGORY FILTER -->

<form action="/shop" method="GET">

  <select name="category">

    <option value="">
      All Categories
    </option>

    <% categories.forEach(cat => { %>

      <option
        value="<%= cat.category %>"
        <%= selectedCategory === cat.category
          ? 'selected'
          : ''
        %>
      >
        <%= cat.category %>
      </option>

    <% }) %>

  </select>

  <button type="submit">
    Filter
  </button>

</form>

<hr>

<!-- PRODUCTS -->

<div class="product-grid">

<% if (products.length === 0) { %>
  <p>No products found</p>
<% } %>

<% products.forEach(product => { %>

  <div class="product-card">
    <form action="/shop/cart" method="POST">

  <input
    type="hidden"
    name="productId"
    value="<%= product.id %>"
  >

  <button type="submit">
    Add to Cart
  </button>

</form>

    <img
      src="/admin/products/<%= product.id %>/image"
      width="200"
    >

    <h3>
      <%= product.name %>
    </h3>

    <p>
      ₹<%= product.price %>
    </p>

    <p>
      Category:
      <%= product.category %>
    </p>

    <a href="/shop/products/<%= product.id %>">
      View Details
    </a>

  </div>

<% }) %>

</div>

<hr>

<!-- PAGINATION -->

<div>

  <% if (hasPreviousPage) { %>

    <a
      href="/shop?page=<%= previousPage %>&category=<%= selectedCategory %>&search=<%= searchTerm %>"
    >
      Previous
    </a>

  <% } %>

  <span>
    Page <%= currentPage %>
  </span>

  <% if (hasNextPage) { %>

    <a
      href="/shop?page=<%= nextPage %>&category=<%= selectedCategory %>&search=<%= searchTerm %>"
    >
      Next
    </a>

  <% } %>

</div>

</body>
</html>