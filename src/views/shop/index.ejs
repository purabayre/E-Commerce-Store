<!DOCTYPE html>
<html>
<head>
  <title>Shop</title>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="/shop/style.css">
  
</head>

<body>

<%- include('../partials/nav') %>

<div class="shop-container">

  <%- include('../partials/flash') %>

  <div class="shop-header">
    <h1 class="shop-title">
      Discover Amazing Products
    </h1>

    <p class="shop-subtitle">
      Explore premium products with modern shopping experience.
    </p>
  </div>

  <!-- FILTERS -->

  <div class="filters-wrapper">

    <!-- SEARCH -->

    <div class="filter-card">

      <label class="filter-label">
        Search Products
      </label>

      <form action="/shop" method="GET">

        <div class="filter-row">

          <input
            type="text"
            name="search"
            class="filter-input"
            placeholder="Search products..."
            value="<%= searchTerm %>"
          >

          <button
            type="submit"
            class="filter-btn"
          >
            Search
          </button>

        </div>

      </form>

    </div>

    <!-- CATEGORY FILTER -->

    <div class="filter-card">

      <label class="filter-label">
        Filter By Category
      </label>

      <form action="/shop" method="GET">

        <div class="filter-row">

          <select
            name="category"
            class="filter-select"
          >

            <option value="">
              All Categories
            </option>

            <% categories.forEach(cat => { %>

              <option
                value="<%= cat.category %>"
                <%= selectedCategory === cat.category
                  ? 'selected'
                  : ''
                %>
              >
                <%= cat.category %>
              </option>

            <% }) %>

          </select>

          <button
            type="submit"
            class="filter-btn"
          >
            Filter
          </button>

        </div>

      </form>

    </div>

  </div>

  <!-- PRODUCTS -->

  <div class="product-grid">

    <% if (products.length === 0) { %>

      <div class="empty-state">

        <h2>
          No Products Found
        </h2>

        <p>
          Try searching with different keywords or categories.
        </p>

      </div>

    <% } %>

    <% products.forEach(product => { %>

      <div class="product-card">

        <div class="product-image-wrapper">

          <img
            src="/admin/products/<%= product.id %>/image"
            alt="<%= product.name %>"
            class="product-image"
          >

        </div>

        <div class="product-content">

          <div class="product-category">
            <%= product.category %>
          </div>

          <h3 class="product-name">
            <%= product.name %>
          </h3>

          <div class="product-price">
            ₹<%= product.price %>
          </div>

          <a
            href="/shop/products/<%= product.id %>"
            class="product-btn"
          >
            View Details
          </a>

        </div>

      </div>

    <% }) %>

  </div>

  <!-- PAGINATION -->

  <div class="pagination">

    <% if (hasPreviousPage) { %>

      <a
        href="/shop?page=<%= previousPage %>&category=<%= selectedCategory %>&search=<%= searchTerm %>"
      >
        ← Previous
      </a>

    <% } %>

    <span>
      Page <%= currentPage %>
    </span>

    <% if (hasNextPage) { %>

      <a
        href="/shop?page=<%= nextPage %>&category=<%= selectedCategory %>&search=<%= searchTerm %>"
      >
        Next →
      </a>

    <% } %>

  </div>

</div>

</body>
</html>