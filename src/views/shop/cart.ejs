<!DOCTYPE html>
<html>
<head>
  <title>Cart</title>
</head>
<body>

<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<h1>Your Cart</h1>

<% if (cart.items.length === 0) { %>

  <p>Your cart is empty</p>

<% } %>

<% cart.items.forEach(item => { %>

  <div>

    <% if (item.product) { %>

      <img
        src="/admin/products/<%= item.product.id %>/image"
        width="120"
      >

      <h3>
        <%= item.product.name %>
      </h3>

      <p>
        ₹<%= item.product.price %>
      </p>

    <% } else { %>

      <h3>
        <%= item.product.name %>
      </h3>

      <p>
        ₹<%= item.product.price %>
      </p>

    <% } %>

    <p>
      Quantity:
      <%= item.quantity %>
    </p>

    <p>
      Subtotal:
      ₹<%= item.subtotal %>
    </p>

    <!-- UPDATE -->

    <form
      action="/shop/cart/update"
      method="POST"
    >

      <% if (isAuthenticated) { %>

        <input
          type="hidden"
          name="cartItemId"
          value="<%= item.id %>"
        >

      <% } else { %>

        <input
          type="hidden"
          name="productId"
          value="<%= item.productId %>"
        >

      <% } %>

      <input
        type="number"
        name="quantity"
        value="<%= item.quantity %>"
        min="1"
      >

      <button type="submit">
        Update
      </button>

    </form>

    <!-- REMOVE -->

    <form
      action="/shop/cart/remove"
      method="POST"
    >

      <% if (isAuthenticated) { %>

        <input
          type="hidden"
          name="cartItemId"
          value="<%= item.id %>"
        >

      <% } else { %>

        <input
          type="hidden"
          name="productId"
          value="<%= item.productId %>"
        >

      <% } %>

      <button type="submit">
        Remove
      </button>

    </form>

    <hr>

  </div>

<% }) %>

<h2>
  Total:
  ₹<%= cart.total %>
</h2>

</body>
</html>