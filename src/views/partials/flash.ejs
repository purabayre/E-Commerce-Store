<style>
  .alert-container {
    width: 100%;
    margin-bottom: 20px;
    font-family: 'Inter', 'Segoe UI', sans-serif;
  }

  .alert {
    position: relative;
    padding: 16px 20px;
    border-radius: 16px;
    font-size: 0.96rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 12px;
    overflow: hidden;
    animation: slideFade 0.35s ease;
    border: 1px solid transparent;
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
  }

  .alert::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 5px;
    height: 100%;
    border-radius: 20px;
  }

  .alert-error {
    background: linear-gradient(135deg, #fef2f2, #fff5f5);
    color: #b91c1c;
    border-color: #fecaca;
  }

  .alert-error::before {
    background: #ef4444;
  }

  .alert-success {
    background: linear-gradient(135deg, #ecfdf5, #f0fdf4);
    color: #166534;
    border-color: #bbf7d0;
  }

  .alert-success::before {
    background: #22c55e;
  }

  .alert-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .alert-text {
    flex: 1;
    line-height: 1.5;
  }

  @keyframes slideFade {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .alert {
      padding: 14px 16px;
      font-size: 0.92rem;
      border-radius: 14px;
    }
  }
</style>

<div class="alert-container">

  <% if (errorMessage.length > 0) { %>
    <div class="alert alert-error">
      <span class="alert-icon">⚠️</span>

      <div class="alert-text">
        <%= errorMessage[0] %>
      </div>
    </div>
  <% } %>

  <% if (successMessage.length > 0) { %>
    <div class="alert alert-success">
      <span class="alert-icon"></span>

      <div class="alert-text">
        <%= successMessage[0] %>
      </div>
    </div>
  <% } %>

</div>