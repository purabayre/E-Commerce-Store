<!DOCTYPE html>
<html>
<head>
  <title><%= pageTitle %></title>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', 'Segoe UI', sans-serif;
      background:
        radial-gradient(circle at top left, #dbeafe 0%, transparent 28%),
        radial-gradient(circle at bottom right, #c7d2fe 0%, transparent 25%),
        linear-gradient(135deg, #f8fafc, #eef2ff);
      min-height: 100vh;
      color: #111827;
    }

    .auth-wrapper {
      min-height: calc(100vh - 90px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
    }

    .auth-card {
      width: 100%;
      max-width: 500px;
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid #e5e7eb;
      border-radius: 32px;
      padding: 42px;
      backdrop-filter: blur(18px);
      box-shadow: 0 25px 60px rgba(15, 23, 42, 0.10);
      position: relative;
      overflow: hidden;
    }

    .auth-card::before {
      content: '';
      position: absolute;
      top: -100px;
      right: -100px;
      width: 220px;
      height: 220px;
      background: rgba(59, 130, 246, 0.08);
      border-radius: 50%;
    }

    .auth-header {
      position: relative;
      z-index: 1;
      text-align: center;
      margin-bottom: 34px;
    }

    .auth-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 8px 16px;
      border-radius: 999px;
      background: #eff6ff;
      color: #2563eb;
      font-size: 0.82rem;
      font-weight: 700;
      margin-bottom: 18px;
    }

    .auth-title {
      font-size: 2.4rem;
      font-weight: 800;
      color: #111827;
      letter-spacing: -1px;
      margin-bottom: 10px;
    }

    .auth-subtitle {
      color: #6b7280;
      font-size: 0.98rem;
      line-height: 1.6;
    }

    .error-box {
      margin-bottom: 24px;
      padding: 18px;
      border-radius: 18px;
      background: linear-gradient(135deg, #fef2f2, #fff5f5);
      border: 1px solid #fecaca;
      box-shadow: 0 10px 24px rgba(239, 68, 68, 0.08);
    }

    .error-box ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .error-box li {
      color: #b91c1c;
      font-weight: 600;
      font-size: 0.94rem;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .error-box li::before {
      content: '⚠️';
      font-size: 0.9rem;
    }

    .auth-form {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      gap: 22px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .form-label {
      font-size: 0.92rem;
      font-weight: 700;
      color: #374151;
    }

    .form-input {
      width: 100%;
      padding: 16px 18px;
      border-radius: 18px;
      border: 1px solid #d1d5db;
      background: rgba(255, 255, 255, 0.96);
      font-size: 0.97rem;
      transition: all 0.25s ease;
      outline: none;
    }

    .form-input:focus {
      border-color: #2563eb;
      box-shadow: 0 0 0 5px rgba(37, 99, 235, 0.10);
      transform: translateY(-1px);
    }

    .form-input::placeholder {
      color: #9ca3af;
    }

    .submit-btn {
      border: none;
      padding: 16px 20px;
      border-radius: 18px;
      background: linear-gradient(135deg, #2563eb, #3b82f6);
      color: white;
      font-size: 1rem;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.28s ease;
      margin-top: 6px;
      box-shadow: 0 18px 35px rgba(37, 99, 235, 0.22);
    }

    .submit-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 22px 42px rgba(37, 99, 235, 0.28);
    }

    .auth-footer {
      margin-top: 26px;
      text-align: center;
      color: #6b7280;
      font-size: 0.94rem;
    }

    .auth-footer a {
      color: #2563eb;
      text-decoration: none;
      font-weight: 700;
      transition: 0.2s ease;
    }

    .auth-footer a:hover {
      color: #1d4ed8;
    }

    @media (max-width: 768px) {

      .auth-wrapper {
        padding: 24px 16px;
      }

      .auth-card {
        padding: 30px 22px;
        border-radius: 26px;
      }

      .auth-title {
        font-size: 2rem;
      }
    }

  </style>
</head>

<body>

  <%- include('../partials/nav') %>

  <div class="auth-wrapper">

    <div class="auth-card">

      <%- include('../partials/flash') %>

      <div class="auth-header">

        <div class="auth-badge">
          Create Your Account
        </div>

        <h1 class="auth-title">
          Register
        </h1>

        <p class="auth-subtitle">

        </p>

      </div>

      <% if (typeof errors !== 'undefined' && errors.length > 0) { %>

        <div class="error-box">

          <ul>

            <% errors.forEach(error => { %>

              <li>
                <%= error.msg %>
              </li>

            <% }) %>

          </ul>

        </div>

      <% } %>

      <form
        action="/auth/register"
        method="POST"
        class="auth-form"
      >

        <div class="form-group">

          <label class="form-label">
            Full Name
          </label>

          <input
            type="text"
            name="name"
            class="form-input"
            placeholder="Enter your full name"
            value="<%= oldInput.name || '' %>"
          >

        </div>

        <div class="form-group">

          <label class="form-label">
            Email Address
          </label>

          <input
            type="email"
            name="email"
            class="form-input"
            placeholder="Enter your email address"
            value="<%= oldInput.email || '' %>"
          >

        </div>

        <div class="form-group">

          <label class="form-label">
            Password
          </label>

          <input
            type="password"
            name="password"
            class="form-input"
            placeholder="Create a strong password"
          >

        </div>

        <div class="form-group">

          <label class="form-label">
            Confirm Password
          </label>

          <input
            type="password"
            name="confirmPassword"
            class="form-input"
            placeholder="Confirm your password"
          >

        </div>

        <button
          type="submit"
          class="submit-btn"
        >
          Create Account
        </button>

      </form>

      <div class="auth-footer">

        Already have an account?

        <a href="/auth/login">
          Login
        </a>

      </div>

    </div>

  </div>

</body>
</html>