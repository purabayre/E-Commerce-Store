<!DOCTYPE html>
<html>
<head>
  <title>Forgot Password</title>

  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <style>

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      overflow: hidden;
      font-family: 'Inter', 'Segoe UI', sans-serif;

      background:
        radial-gradient(circle at top left, #dbeafe 0%, transparent 28%),
        radial-gradient(circle at bottom right, #c7d2fe 0%, transparent 25%),
        linear-gradient(135deg, #f8fafc, #eef2ff);

      position: relative;
    }

    body::before {
      content: '';
      position: absolute;
      top: -180px;
      left: -180px;
      width: 420px;
      height: 420px;
      background: rgba(37, 99, 235, 0.10);
      border-radius: 50%;
      filter: blur(20px);
    }

    body::after {
      content: '';
      position: absolute;
      bottom: -180px;
      right: -180px;
      width: 420px;
      height: 420px;
      background: rgba(99, 102, 241, 0.10);
      border-radius: 50%;
      filter: blur(20px);
    }

    .forgot-container {
      width: 100%;
      max-width: 560px;
      padding: 52px 42px;
      border-radius: 36px;

      background: rgba(255, 255, 255, 0.92);
      border: 1px solid #e5e7eb;
      backdrop-filter: blur(18px);

      box-shadow:
        0 30px 70px rgba(15, 23, 42, 0.10),
        0 10px 25px rgba(15, 23, 42, 0.06);

      position: relative;
      z-index: 2;
      overflow: hidden;
    }

    .forgot-container::before {
      content: '';
      position: absolute;
      top: -120px;
      right: -120px;
      width: 260px;
      height: 260px;
      background: rgba(37, 99, 235, 0.08);
      border-radius: 50%;
    }

    .forgot-badge {
      width: fit-content;
      padding: 10px 18px;
      border-radius: 999px;
      background: #eff6ff;
      color: #2563eb;
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.3px;
      margin-bottom: 22px;
      border: 1px solid #bfdbfe;
      position: relative;
      z-index: 1;
    }

    .forgot-title {
      font-size: 2.6rem;
      font-weight: 800;
      color: #111827;
      letter-spacing: -1px;
      margin-bottom: 16px;
      position: relative;
      z-index: 1;
    }

    .forgot-subtitle {
      color: #6b7280;
      font-size: 1rem;
      line-height: 1.9;
      margin-bottom: 36px;
      position: relative;
      z-index: 1;
    }

    .alert-box {
      margin-bottom: 24px;
      padding: 16px 18px;
      border-radius: 18px;
      font-size: 0.94rem;
      font-weight: 600;
      line-height: 1.7;
      position: relative;
      z-index: 1;
    }

    .alert-error {
      background: linear-gradient(135deg, #fef2f2, #fff5f5);
      border: 1px solid #fecaca;
      color: #b91c1c;
    }

    .alert-success {
      background: linear-gradient(135deg, #ecfdf5, #f0fdf4);
      border: 1px solid #bbf7d0;
      color: #15803d;
    }

    .forgot-form {
      display: flex;
      flex-direction: column;
      gap: 24px;
      position: relative;
      z-index: 1;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .form-label {
      font-size: 0.92rem;
      font-weight: 700;
      color: #374151;
    }

    .form-input {
      width: 100%;
      padding: 18px 20px;
      border-radius: 18px;
      border: 1px solid #d1d5db;
      background: rgba(255, 255, 255, 0.96);
      font-size: 0.98rem;
      transition: all 0.25s ease;
      outline: none;
      font-family: inherit;
    }

    .form-input:focus {
      border-color: #2563eb;
      box-shadow: 0 0 0 5px rgba(37, 99, 235, 0.10);
      transform: translateY(-1px);
    }

    .submit-btn {
      width: 100%;
      border: none;
      border-radius: 18px;
      padding: 18px 20px;
      background: linear-gradient(135deg, #2563eb, #3b82f6);
      color: white;
      font-size: 1rem;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.28s ease;
      box-shadow: 0 18px 35px rgba(37, 99, 235, 0.22);
      font-family: inherit;
    }

    .submit-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 24px 44px rgba(37, 99, 235, 0.28);
    }

    .bottom-links {
      margin-top: 30px;
      display: flex;
      justify-content: center;
      gap: 18px;
      flex-wrap: wrap;
      position: relative;
      z-index: 1;
    }

    .bottom-link {
      color: #2563eb;
      font-weight: 700;
      text-decoration: none;
      transition: all 0.25s ease;
    }

    .bottom-link:hover {
      color: #1d4ed8;
      text-decoration: underline;
    }

    @media (max-width: 768px) {

      .forgot-container {
        padding: 42px 24px;
        border-radius: 28px;
      }

      .forgot-title {
        font-size: 2rem;
      }

      .forgot-subtitle {
        font-size: 0.95rem;
      }

      .bottom-links {
        flex-direction: column;
        align-items: center;
      }
    }

  </style>
</head>

<body>

  <div class="forgot-container">

    <div class="forgot-badge">
      🔐 Account Recovery
    </div>

    <h1 class="forgot-title">
      Forgot Password
    </h1>

    <p class="forgot-subtitle">
      Enter your registered email address and we’ll send you a secure password
      reset link to recover your account.
    </p>

    <%- include('../partials/flash') %>

    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>

      <div class="alert-box alert-error">

        <% errors.forEach(error => { %>

          <div>
            • <%= error.msg %>
          </div>

        <% }) %>

      </div>

    <% } %>

    <form
  action="/auth/forgot-password"
  method="POST"
  class="forgot-form"
>

  <input
    type="hidden"
    name="_csrf"
    value="<%= csrfToken %>"
  >

  <div class="form-group">

        <label class="form-label">
          Email Address
        </label>

        <input
          type="email"
          name="email"
          class="form-input"
          placeholder="Enter your email"
          required
        >

      </div>

      <button
        type="submit"
        class="submit-btn"
      >
        Send Reset Link
      </button>

    </form>

    <div class="bottom-links">

      <a
        href="/auth/login"
        class="bottom-link"
      >
        Back to Login
      </a>

      <a
        href="/auth/register"
        class="bottom-link"
      >
        Create Account
      </a>

    </div>

  </div>

</body>
</html>