<!DOCTYPE html>
<html>
<head>
  <title>Add Product</title>
</head>
<body>

<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<h1>Add Product</h1>

<% if (errors.length > 0) { %>
  <ul>
    <% errors.forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<form
  action="/admin/products"
  method="POST"
  enctype="multipart/form-data"
>

  <input
    type="text"
    name="name"
    placeholder="Name"
    value="<%= oldInput.name || '' %>"
  >

  <br><br>

  <textarea
    name="description"
    placeholder="Description"
  ><%= oldInput.description || '' %></textarea>

  <br><br>

  <input
    type="number"
    step="0.01"
    name="price"
    placeholder="Price"
    value="<%= oldInput.price || '' %>"
  >

  <br><br>

  <input
    type="number"
    name="stock"
    placeholder="Stock"
    value="<%= oldInput.stock || '' %>"
  >

  <br><br>

  <input
    type="text"
    name="category"
    placeholder="Category"
    value="<%= oldInput.category || '' %>"
  >

  <br><br>

  <input type="file" name="image">

  <br><br>

  <button type="submit">
    Add Product
  </button>

</form>

</body>
</html>