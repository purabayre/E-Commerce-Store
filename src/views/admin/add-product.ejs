<!DOCTYPE html>
<html>
<head>
  <title>Add Product</title>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet" href="/admin/style.css">
</head>

<body>

<%- include('../partials/nav') %>

<div class="page-wrapper">

  <div class="product-form-card">

    <%- include('../partials/flash') %>

    <div class="page-header">

      <div class="page-badge">
        📦 Admin Dashboard
      </div>

      <h1 class="page-title">
        Add Product
      </h1>

      <p class="page-subtitle">
        Create and publish a new product for your modern e-commerce store.
      </p>

    </div>

    <% if (errors && errors.length > 0) { %>

      <div class="error-box">

        <ul>

          <% errors.forEach(error => { %>

            <li>
              <%= error.msg %>
            </li>

          <% }) %>

        </ul>

      </div>

    <% } %>

    <form
      action="/admin/products"
      method="POST"
      enctype="multipart/form-data"
      class="product-form"
    >

 

      <div class="form-grid">

        <div class="form-group full-width">

          <label class="form-label">
            Product Name
          </label>

          <input
            type="text"
            name="name"
            class="form-input"
            placeholder="Enter product name"
            value="<%= oldInput?.name || '' %>"
          >

        </div>

        <div class="form-group full-width">

          <label class="form-label">
            Product Description
          </label>

          <textarea
            name="description"
            class="form-textarea"
            placeholder="Write detailed product description..."
          ><%= oldInput?.description || '' %></textarea>

        </div>

        <div class="form-group">

          <label class="form-label">
            Product Price
          </label>

          <input
            type="number"
            step="0.01"
            name="price"
            class="form-input"
            placeholder="Enter price"
            value="<%= oldInput?.price || '' %>"
          >

        </div>

        <div class="form-group">

          <label class="form-label">
            Stock Quantity
          </label>

          <input
            type="number"
            name="stock"
            class="form-input"
            placeholder="Available stock"
            value="<%= oldInput?.stock || '' %>"
          >

        </div>

        <div class="form-group full-width">

          <label class="form-label">
            Product Category
          </label>

          <input
            type="text"
            name="category"
            class="form-input"
            placeholder="Enter category"
            value="<%= oldInput?.category || '' %>"
          >

        </div>

        <div class="form-group full-width">

          <label class="form-label">
            Product Image
          </label>

          <div class="file-upload-box">

            <input
              type="file"
              name="image"
              class="form-file"
            >

            <div class="file-upload-text">
              Upload a high-quality product image for better customer engagement.
            </div>

          </div>

        </div>

      </div>

      <button
        type="submit"
        class="submit-btn"
      >
        Add Product
      </button>

    </form>

  </div>

</div>

</body>
</html>