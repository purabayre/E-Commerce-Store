<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard</title>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link
    rel="stylesheet"
    href="/admin/style.css"
  >
</head>

<body>

<%- include('../partials/nav') %>

<div class="page-wrapper">

  <!-- ADD PRODUCT SECTION -->

  <div class="product-form-card">

    <%- include('../partials/flash') %>

    <div class="page-header">

      <div class="page-badge">
        📦 Admin Dashboard
      </div>

      <h1 class="page-title">
        Add Product
      </h1>

      <p class="page-subtitle">
        Create and publish a new product for your modern e-commerce store.
      </p>

    </div>

    <% if (errors.length > 0) { %>

      <div class="error-box">

        <ul>

          <% errors.forEach(error => { %>

            <li>
              <%= error.msg %>
            </li>

          <% }) %>

        </ul>

      </div>

    <% } %>

    <form
      action="/admin/products"
      method="POST"
      enctype="multipart/form-data"
      class="product-form"
    >

      <input
        type="hidden"
        name="_csrf"
        value="<%= csrfToken %>"
      >

      <div class="form-grid">

        <div class="form-group full-width">

          <label class="form-label">
            Product Name
          </label>

          <input
            type="text"
            name="name"
            class="form-input"
            placeholder="Enter product name"
            value="<%= oldInput.name || '' %>"
          >

        </div>

        <div class="form-group full-width">

          <label class="form-label">
            Product Description
          </label>

          <textarea
            name="description"
            class="form-textarea"
            placeholder="Write detailed product description..."
          ><%= oldInput.description || '' %></textarea>

        </div>

        <div class="form-group">

          <label class="form-label">
            Product Price
          </label>

          <input
            type="number"
            step="0.01"
            name="price"
            class="form-input"
            placeholder="Enter price"
            value="<%= oldInput.price || '' %>"
          >

        </div>

        <div class="form-group">

          <label class="form-label">
            Stock Quantity
          </label>

          <input
            type="number"
            name="stock"
            class="form-input"
            placeholder="Available stock"
            value="<%= oldInput.stock || '' %>"
          >

        </div>

        <div class="form-group full-width">

          <label class="form-label">
            Product Category
          </label>

          <input
            type="text"
            name="category"
            class="form-input"
            placeholder="Enter category"
            value="<%= oldInput.category || '' %>"
          >

        </div>

        <div class="form-group full-width">

          <label class="form-label">
            Product Image
          </label>

          <div class="file-upload-box">

            <input
              type="file"
              name="image"
              class="form-file"
            >

            <div class="file-upload-text">
              Upload a high-quality product image for better customer engagement.
            </div>

          </div>

        </div>

      </div>

      <button
        type="submit"
        class="submit-btn"
      >
        Add Product
      </button>

    </form>

  </div>



  <!-- ORDERS SECTION -->
<div class="admin-orders-page">

  <div class="orders-header">

    <div>

      <div class="page-badge">
        Admin Dashboard
      </div>

      <h1 class="orders-title">
        Manage Orders
      </h1>

      <p class="orders-subtitle">
        Track, manage, and update customer orders.
      </p>

    </div>

  </div>

  <% if (orders.length === 0) { %>

    <div class="empty-orders">

      <h2>
        No Orders Found
      </h2>

      <p>
        Orders will appear here once customers place them.
      </p>

    </div>

  <% } else { %>

    <div class="orders-table-wrapper">

      <table class="orders-table">

        <thead>

          <tr>

            <th>
              Order ID
            </th>

            <th>
              Customer
            </th>

            <th>
              Products
            </th>

            <th>
              Total
            </th>

            <th>
              Status
            </th>

            <th>
              Date
            </th>

            <th>
              Action
            </th>

          </tr>

        </thead>

        <tbody>

          <% orders.forEach(order => { %>

            <tr>

              <!-- ORDER ID -->

              <td>
                #<%= order.id %>
              </td>

              <!-- CUSTOMER -->

              <td>

                <div class="customer-name">
                  <%= order.User.name %>
                </div>

                <div class="customer-email">
                  <%= order.User.email %>
                </div>

              </td>

              <!-- PRODUCTS -->

              <td>

                <% order.OrderItems.forEach(item => { %>

                  <div class="table-product-item">

                    <strong>
                      <%= item.Product.name %>
                    </strong>

                    <br>

                    Qty: <%= item.quantity %>

                    × ₹<%= item.price %>

                  </div>

                <% }) %>

              </td>

              <!-- TOTAL -->

              <td>
                ₹<%= order.totalAmount %>
              </td>

              <!-- STATUS -->

              <td>

                <span class="status-badge status-<%= order.status %>">
                  <%= order.status %>
                </span>

                <div class="timeline-mini">

                  <span class="<%= order.pendingAt ? 'active' : '' %>">
                    Pending
                  </span>

                  <span class="<%= order.processingAt ? 'active' : '' %>">
                    Processing
                  </span>

                  <span class="<%= order.shippedAt ? 'active' : '' %>">
                    Shipped
                  </span>

                  <span class="<%= order.deliveredAt ? 'active' : '' %>">
                    Delivered
                  </span>

                </div>

              </td>

              <!-- DATE -->

              <td>

                <%= new Date(order.createdAt)
                  .toLocaleDateString()
                %>

              </td>

              <!-- ACTION -->

              <td>

                <form
                  action="/admin/orders/<%= order.id %>/status"
                  method="POST"
                  class="status-form"
                >

                  <input
                    type="hidden"
                    name="_csrf"
                    value="<%= csrfToken %>"
                  >

                  <button
                    type="submit"
                    class="update-btn"
                  >
                    Update
                  </button>

                </form>

              </td>

            </tr>

          <% }) %>

        </tbody>

      </table>

    </div>

  <% } %>

</div>

</body>
</html>