<!DOCTYPE html>
<html>
<head>
  <title>Edit Product</title>
</head>
<body>

<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<h1>Edit Product</h1>

<% if (errors.length > 0) { %>
  <ul>
    <% errors.forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<form
  action="/admin/products/<%= product.id %>"
  method="POST"
  enctype="multipart/form-data"
>

  <img
    src="/admin/products/<%= product.id %>/image"
    width="150"
  >

  <br><br>

  <input
    type="text"
    name="name"
    value="<%= product.name %>"
  >

  <br><br>

  <textarea
    name="description"
  ><%= product.description %></textarea>

  <br><br>

  <input
    type="number"
    step="0.01"
    name="price"
    value="<%= product.price %>"
  >

  <br><br>

  <input
    type="number"
    name="stock"
    value="<%= product.stock %>"
  >

  <br><br>

  <input
    type="text"
    name="category"
    value="<%= product.category %>"
  >

  <br><br>

  <input type="file" name="image">

  <br><br>

  <button type="submit">
    Save Changes
  </button>

</form>

</body>
</html>