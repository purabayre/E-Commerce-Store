<!DOCTYPE html>
<html>
<head>
  <title>Edit Product</title>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet" href="/admin/style.css">
</head>

<body>

<%- include('../partials/nav') %>

<div class="page-wrapper">

  <div class="edit-card">

    <%- include('../partials/flash') %>

    <div class="page-header">

      <div class="page-badge">
        ✏️ Product Management
      </div>

      <h1 class="page-title">
        Edit Product
      </h1>

      <p class="page-subtitle">
        Update product information, improve listings, and keep your store inventory fresh and accurate.
      </p>

    </div>

    <% if (errors && errors.length > 0) { %>

      <div class="error-box">

        <ul>

          <% errors.forEach(error => { %>

            <li>
              <%= error.msg %>
            </li>

          <% }) %>

        </ul>

      </div>

    <% } %>

    <div class="edit-layout">

      <!-- IMAGE SECTION -->

      <div class="image-section">

        <div class="image-card">

          <img
            src="/admin/products/<%= product.id %>/image"
            alt="<%= product.name %>"
            class="product-image"
          >

          <div class="image-label">
            Current Product Image
          </div>

        </div>

      </div>

      <!-- FORM SECTION -->

      <form
  action="/admin/products/<%= product.id %>"
  method="POST"
  enctype="multipart/form-data"
  class="edit-form"
>

  <input
    type="hidden"
    name="_csrf"
    value="<%= csrfToken %>"
  >

  <div class="form-grid">

          <div class="form-group full-width">

            <label class="form-label">
              Product Name
            </label>

            <input
              type="text"
              name="name"
              class="form-input"
              value="<%= product?.name || '' %>"
            >

          </div>

          <div class="form-group full-width">

            <label class="form-label">
              Product Description
            </label>

            <textarea
              name="description"
              class="form-textarea"
            ><%= product?.description || '' %></textarea>

          </div>

          <div class="form-group">

            <label class="form-label">
              Product Price
            </label>

            <input
              type="number"
              step="0.01"
              name="price"
              class="form-input"
              value="<%= product?.price || '' %>"
            >

          </div>

          <div class="form-group">

            <label class="form-label">
              Stock Quantity
            </label>

            <input
              type="number"
              name="stock"
              class="form-input"
              value="<%= product?.stock || '' %>"
            >

          </div>

          <div class="form-group full-width">

            <label class="form-label">
              Product Category
            </label>

            <input
              type="text"
              name="category"
              class="form-input"
              value="<%= product?.category || '' %>"
            >

          </div>

          <div class="form-group full-width">

            <label class="form-label">
              Replace Product Image
            </label>

            <div class="upload-box">

              <input
                type="file"
                name="image"
                class="form-file"
              >

              <div class="upload-text">
                Upload a new image only if you want to replace the current product image.
              </div>

            </div>

          </div>

        </div>

        <div class="form-actions">

          <button
            type="submit"
            class="btn btn-primary"
          >
            Save Changes
          </button>

          <a
            href="/admin/products"
            class="btn btn-secondary"
          >
            Back to Products
          </a>

        </div>

      </form>

    </div>

  </div>

</div>

</body>
</html>